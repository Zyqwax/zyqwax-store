# MongoDB bağlantı adresi
MONGODB_URI=mongodb://localhost:27017/zyqwax-store
# veya MongoDB Atlas:
# MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/zyqwax-store

# JWT gizli anahtarı (en az 32 karakter, güçlü rastgele string)
JWT_SECRET=change-this-to-a-very-long-random-secret-key-minimum-32-chars

# İlk admin hesabı (seed script için)
ADMIN_EMAIL=admin@zyqwax.com
ADMIN_PASSWORD=Admin123!
